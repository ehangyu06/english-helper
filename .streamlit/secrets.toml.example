# =============================================================================
#  Supabase 연결용 비밀키 예시 파일
# -----------------------------------------------------------------------------
#  [로컬 테스트] 이 파일을 같은 폴더에 "secrets.toml" 이라는 이름으로 복사한 뒤
#               아래 값을 채우면 내 컴퓨터에서도 Supabase에 저장됩니다.
#               (값을 채우지 않으면 자동으로 로컬 SQLite를 사용합니다.)
#
#  [Streamlit Cloud 배포] 이 파일을 올릴 필요는 없습니다. 대신 Streamlit Cloud
#               앱 설정의 "Secrets" 칸에 아래 [supabase] 블록 내용을 그대로
#               붙여넣으면 됩니다.
#
#  ⚠️ 실제 secrets.toml 파일은 .gitignore에 의해 GitHub에 올라가지 않습니다.
#     비밀키는 절대 공개 저장소에 올리지 마세요!
# =============================================================================

[supabase]
url = "https://여기에-프로젝트-주소.supabase.co"
key = "여기에-service_role-키-붙여넣기"
